// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  interest  Interest
  ip        String
  createdAt DateTime @default(now())
}

enum Interest {
  sim
  nao
  talvez
}

model RateLimit {
  id        Int      @id @default(autoincrement())
  ip        String
  count     Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ip])
}

model Company {
  id                  String       @id @default(cuid())
  nomeFantasia        String
  razaoSocial         String?
  cnpjCpf             String       @unique
  endereco            String?
  telefone            String?
  email               String?
  whatsappEnabled     Boolean      @default(false)
  whatsappNumber      String?
  uazapiInstanceName  String?
  uazapiInstanceToken String?
  uazapiConnected     Boolean      @default(false)
  uazapiProfileName   String?
  contrato            ContractType @default(TRIAL)
  trialEndsAt         DateTime?
  subscriptionStatus  String?      @default("trial")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  users                User[]
  appointments         Appointment[]
  clients              Client[]
  workingHours         WorkingHours[]
  services             Service[]
  companyPage          CompanyPage?
  subscription         Subscription?
  tags                 Tag[]
  supportConversations SupportConversation[]
}

enum ContractType {
  TRIAL
  BASIC
  PROFESSIONAL
  PRO_PLUS
  BUSINESS
}

model WorkingHours {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  dayOfWeek Int // 0 = Domingo, 6 = Sábado
  openTime  String // formato HH:mm
  closeTime String // formato HH:mm
}

model WorkingHourException {
  id             String        @id @default(cuid())
  companyId      String
  professionalId String? // Null = aplica para toda empresa
  date           DateTime // Data específica da exceção
  type           ExceptionType
  reason         String? // Motivo (feriado, férias, etc)
  openTime       String? // Para tipo CUSTOM: horário de abertura
  closeTime      String? // Para tipo CUSTOM: horário de fechamento
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId, date])
  @@index([professionalId, date])
}

enum ExceptionType {
  BLOCKED // Dia totalmente bloqueado
  CUSTOM // Horário customizado para o dia
  HOLIDAY // Feriado
}

model Service {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  price     Float
  duration  Int // em minutos
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments  Appointment[]
  professionals ProfessionalService[]
}

model ProfessionalService {
  id             String @id @default(cuid())
  professionalId String
  serviceId      String

  professional User    @relation(fields: [professionalId], references: [id])
  service      Service @relation(fields: [serviceId], references: [id])

  @@unique([professionalId, serviceId]) // um profissional não pode ter o mesmo serviço duplicado
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OWNER)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  // Perfil do Profissional
  photoUrl       String? // URL da foto do profissional
  bio            String? @db.Text // Biografia/descrição do profissional
  commissionRate Float?  @default(0) // Taxa de comissão em % (ex: 30.5 = 30.5%)

  // Trial de 14 dias
  trialEndsAt DateTime? // Data de término do período de teste (null = sem trial ou já converteu)

  // Verificação de email
  emailVerified      Boolean   @default(false) // Se o email foi verificado
  verificationToken  String?   @unique // Token para verificação de email
  verificationSentAt DateTime? // Quando o email de verificação foi enviado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments                 Appointment[]         @relation("UserAppointments")
  services                     ProfessionalService[]
  loginHistory                 LoginHistory[]
  sessions                     UserSession[]
  auditLogs                    AuditLog[]
  securitySettings             UserSecuritySettings?
  supportConversations         SupportConversation[]
  assignedSupportConversations SupportConversation[] @relation("AssignedSupport")
  supportMessages              SupportMessage[]
}

enum Role {
  OWNER // Dono/autônomo da empresa
  MANAGER // Líder/supervisor
  EMPLOYEE // Funcionário comum
}

model Appointment {
  id             String            @id @default(cuid())
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id])
  professionalId String
  professional   User              @relation("UserAppointments", fields: [professionalId], references: [id])
  clientName     String
  clientId       String?
  client         Client?           @relation(fields: [clientId], references: [id])
  serviceId      String
  service        Service           @relation(fields: [serviceId], references: [id])
  price          Float?
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(PENDING)
  reminderSentAt DateTime?

  // Controle Financeiro
  paymentStatus PaymentStatusType @default(PENDING)
  paidAmount    Float?            @default(0) // Valor já pago
  paymentMethod String? // pix, dinheiro, cartao_credito, cartao_debito, etc
  paymentDate   DateTime? // Data do pagamento

  // Comissões
  commissionRate   Float?    @default(0) // Taxa de comissão aplicada no momento (%)
  commissionAmount Float?    @default(0) // Valor da comissão calculada
  commissionPaid   Boolean   @default(false) // Comissão já foi paga ao profissional?
  commissionPaidAt DateTime? // Data do pagamento da comissão

  notes String? @db.Text // Observações sobre pagamento ou agendamento

  // Agendamentos Recorrentes
  recurrenceRule      String? // RRULE format: FREQ=WEEKLY;INTERVAL=1;BYDAY=MO,WE,FR ou "WEEKLY" | "BIWEEKLY" | "MONTHLY"
  recurrenceEndDate   DateTime? // Data final da recorrência
  parentAppointmentId String? // ID do agendamento pai (para rastrear série)
  parentAppointment   Appointment?  @relation("RecurringAppointments", fields: [parentAppointmentId], references: [id], onDelete: Cascade)
  childAppointments   Appointment[] @relation("RecurringAppointments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([reminderSentAt])
}

enum PaymentStatusType {
  PENDING // Aguardando pagamento
  PAID // Pago completamente
  PARTIAL // Pagamento parcial
  CANCELED // Cancelado (não cobrar)
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

model Client {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  tags         ClientTag[]
}

model Tag {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  color     String   @default("#6366f1") // Cor da tag em hex
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients ClientTag[]

  @@unique([companyId, name]) // Tag única por empresa
}

model ClientTag {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([clientId, tagId]) // Cliente não pode ter a mesma tag duplicada
}

model CompanyPage {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id])
  slug             String   @unique // URL amigável: /slug
  title            String // Nome da empresa na página
  slogan           String? // Slogan/frase de impacto
  description      String?  @db.Text // Descrição/história
  logo             String? // URL do logo
  coverImage       String? // Imagem de capa
  primaryColor     String   @default("#6366f1") // Cor primária da marca
  accentColor      String   @default("#3b82f6") // Cor de acento
  whatsapp         String? // Número do WhatsApp
  instagram        String? // URL do Instagram
  facebook         String? // URL do Facebook
  address          String? // Endereço físico
  showServices     Boolean  @default(true)
  showTestimonials Boolean  @default(true)
  showAbout        Boolean  @default(true)
  metaTitle        String? // SEO
  metaDescription  String? // SEO
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  testimonials PageTestimonial[]
}

model PageTestimonial {
  id            String      @id @default(cuid())
  companyPageId String
  companyPage   CompanyPage @relation(fields: [companyPageId], references: [id], onDelete: Cascade)
  authorName    String
  authorAvatar  String? // Iniciais ou URL
  rating        Int         @default(5) // 1-5 estrelas
  text          String      @db.Text
  position      Int         @default(0) // Ordem de exibição
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Subscription {
  id                   String             @id @default(cuid())
  companyId            String             @unique
  company              Company            @relation(fields: [companyId], references: [id])
  plan                 SubscriptionPlan   @default(TRIAL)
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique // ID da assinatura no Stripe
  stripeCustomerId     String?
  stripePriceId        String?
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime? // Null para plano FREE
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  trialEndsAt          DateTime? // Para trial de 14 dias
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  payments Payment[]
}

enum SubscriptionPlan {
  TRIAL // Trial de 14 dias com acesso completo
  BASIC // R$ 69.90/mês, 1 profissional, sem WhatsApp
  PROFESSIONAL // R$ 99.90/mês, 3 profissionais, WhatsApp, relatórios
  PRO_PLUS // R$ 129.90/mês, 10 profissionais, comissões, fotos
  BUSINESS // R$ 169.90/mês, ilimitado, comissões, suporte 24/7
}

enum SubscriptionStatus {
  ACTIVE // Assinatura ativa
  PAST_DUE // Pagamento atrasado
  CANCELED // Cancelada
  TRIALING // Em período de teste
}

model Payment {
  id                    String        @id @default(cuid())
  subscriptionId        String
  subscription          Subscription  @relation(fields: [subscriptionId], references: [id])
  stripePaymentIntentId String?       @unique // ID do pagamento no Stripe
  amount                Float
  currency              String        @default("BRL")
  status                PaymentStatus @default(PENDING)
  paymentMethod         String? // pix, credit_card, debit_card, boleto
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([subscriptionId])
}

enum PaymentStatus {
  PENDING // Aguardando pagamento
  APPROVED // Pagamento aprovado
  AUTHORIZED // Autorizado (cartão)
  IN_PROCESS // Em processamento
  IN_MEDIATION // Em mediação
  REJECTED // Rejeitado
  CANCELLED // Cancelado
  REFUNDED // Reembolsado
  CHARGED_BACK // Chargeback
}

// Histórico de logins para auditoria e segurança
model LoginHistory {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip           String
  userAgent    String
  device       String? // Mobile, Desktop, Tablet
  browser      String? // Chrome, Firefox, Safari, etc
  os           String? // Windows, macOS, Linux, iOS, Android
  location     String? // Cidade/País (se disponível)
  success      Boolean // Se o login foi bem-sucedido
  failReason   String? // Motivo da falha (se aplicável)
  sessionToken String? // Token da sessão (para rastreamento)
  loggedOutAt  DateTime? // Quando fez logout
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([ip])
  @@index([sessionToken])
}

// Tentativas de login falhadas (para proteção contra brute force)
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ip, createdAt])
}

// Sessões ativas dos usuários
model UserSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String    @unique // JWT token
  ip           String
  userAgent    String
  device       String?
  browser      String?
  os           String?
  lastActivity DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime? // Para logout manual
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

// Logs de auditoria para ações sensíveis
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId String?
  action    String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc
  entity    String // User, Appointment, Client, etc
  entityId  String?
  changes   Json? // Objeto com as mudanças (before/after)
  ip        String
  userAgent String
  success   Boolean  @default(true)
  errorMsg  String?
  metadata  Json? // Dados adicionais contextuais
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([companyId, createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
}

// Configurações de segurança por usuário
model UserSecuritySettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  twoFactorEnabled        Boolean  @default(false)
  twoFactorSecret         String? // Segredo do TOTP
  backupCodes             String[] // Códigos de backup (hasheados)
  loginNotifications      Boolean  @default(true) // Notificar novos logins
  suspiciousActivityAlert Boolean  @default(true)
  lastPasswordChange      DateTime @default(now())
  passwordExpiryDays      Int      @default(90) // Dias para expirar senha
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
}

// Sistema de Suporte - Conversas
model SupportConversation {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      String // Assunto da conversa
  status       SupportStatus    @default(OPEN)
  assignedToId String? // Staff que atendeu
  assignedTo   User?            @relation("AssignedSupport", fields: [assignedToId], references: [id], onDelete: SetNull)
  closedAt     DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  messages     SupportMessage[]

  @@index([companyId, status])
  @@index([userId])
  @@index([assignedToId])
  @@index([status, updatedAt])
}

// Sistema de Suporte - Mensagens
model SupportMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String              @db.Text
  isStaff        Boolean             @default(false) // true se enviado por @tolivre.app
  readAt         DateTime? // Timestamp de leitura
  createdAt      DateTime            @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// Enum para status das conversas de suporte
enum SupportStatus {
  OPEN // Aberta, aguardando atendimento
  IN_PROGRESS // Em atendimento
  CLOSED // Fechada/Resolvida
}
