// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  interest  Interest
  ip        String
  createdAt DateTime @default(now())
}

enum Interest {
  sim
  nao
  talvez
}

model RateLimit {
  id        Int      @id @default(autoincrement())
  ip        String
  count     Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ip])
}

model Company {
  id           String       @id @default(cuid())
  nomeFantasia String
  razaoSocial  String?
  cnpjCpf      String       @unique
  endereco     String?
  telefone     String?
  email        String?
  contrato     ContractType @default(FREE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users        User[]
  appointments Appointment[]
  clients      Client[]
  workingHours WorkingHours[]
  services     Service[]
  companyPage  CompanyPage?
  subscription Subscription?
  tags         Tag[]
}

enum ContractType {
  FREE
  PRO
  PREMIUM
  ENTERPRISE
}

model WorkingHours {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  dayOfWeek Int // 0 = Domingo, 6 = Sábado
  openTime  String // formato HH:mm
  closeTime String // formato HH:mm
}

model Service {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  price     Float
  duration  Int // em minutos
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments  Appointment[]
  professionals ProfessionalService[]
}

model ProfessionalService {
  id             String @id @default(cuid())
  professionalId String
  serviceId      String

  professional User    @relation(fields: [professionalId], references: [id])
  service      Service @relation(fields: [serviceId], references: [id])

  @@unique([professionalId, serviceId]) // um profissional não pode ter o mesmo serviço duplicado
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OWNER)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]         @relation("UserAppointments")
  services     ProfessionalService[]
}

enum Role {
  OWNER // Dono/autônomo da empresa
  MANAGER // Líder/supervisor
  EMPLOYEE // Funcionário comum
}

model Appointment {
  id             String            @id @default(cuid())
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id])
  professionalId String
  professional   User              @relation("UserAppointments", fields: [professionalId], references: [id])
  clientName     String
  clientId       String?
  client         Client?           @relation(fields: [clientId], references: [id])
  serviceId      String
  service        Service           @relation(fields: [serviceId], references: [id])
  price          Float?
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(PENDING)

  // Controle Financeiro
  paymentStatus  PaymentStatusType @default(PENDING)
  paidAmount     Float?            @default(0) // Valor já pago
  paymentMethod  String? // pix, dinheiro, cartao_credito, cartao_debito, etc
  paymentDate    DateTime? // Data do pagamento
  notes          String?           @db.Text // Observações sobre pagamento ou agendamento

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentStatusType {
  PENDING // Aguardando pagamento
  PAID // Pago completamente
  PARTIAL // Pagamento parcial
  CANCELED // Cancelado (não cobrar)
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

model Client {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  tags         ClientTag[]
}

model Tag {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  color     String   @default("#6366f1") // Cor da tag em hex
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients ClientTag[]

  @@unique([companyId, name]) // Tag única por empresa
}

model ClientTag {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([clientId, tagId]) // Cliente não pode ter a mesma tag duplicada
}

model CompanyPage {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id])
  slug             String   @unique // URL amigável: /slug
  title            String // Nome da empresa na página
  description      String?  @db.Text // Descrição/história
  logo             String? // URL do logo
  coverImage       String? // Imagem de capa
  primaryColor     String   @default("#6366f1") // Cor primária da marca
  accentColor      String   @default("#3b82f6") // Cor de acento
  whatsapp         String? // Número do WhatsApp
  instagram        String? // URL do Instagram
  facebook         String? // URL do Facebook
  address          String? // Endereço físico
  showServices     Boolean  @default(true)
  showTestimonials Boolean  @default(true)
  showAbout        Boolean  @default(true)
  metaTitle        String? // SEO
  metaDescription  String? // SEO
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  testimonials PageTestimonial[]
}

model PageTestimonial {
  id            String      @id @default(cuid())
  companyPageId String
  companyPage   CompanyPage @relation(fields: [companyPageId], references: [id], onDelete: Cascade)
  authorName    String
  authorAvatar  String? // Iniciais ou URL
  rating        Int         @default(5) // 1-5 estrelas
  text          String      @db.Text
  position      Int         @default(0) // Ordem de exibição
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Subscription {
  id                  String             @id @default(cuid())
  companyId           String             @unique
  company             Company            @relation(fields: [companyId], references: [id])
  plan                SubscriptionPlan   @default(FREE)
  status              SubscriptionStatus @default(ACTIVE)
  mpSubscriptionId    String?            @unique // ID da assinatura no Mercado Pago
  mpPreapprovalPlanId String? // ID do plano de assinatura no MP
  currentPeriodStart  DateTime           @default(now())
  currentPeriodEnd    DateTime? // Null para plano FREE
  cancelAtPeriodEnd   Boolean            @default(false)
  canceledAt          DateTime?
  trialEndsAt         DateTime? // Para trial de 14 dias
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  payments Payment[]
}

enum SubscriptionPlan {
  FREE // 50 agendamentos/mês, 1 profissional
  PROFESSIONAL // Ilimitado, 3 profissionais, WhatsApp
  ENTERPRISE // Ilimitado, profissionais ilimitados, API
}

enum SubscriptionStatus {
  ACTIVE // Assinatura ativa
  PAST_DUE // Pagamento atrasado
  CANCELED // Cancelada
  TRIALING // Em período de teste
}

model Payment {
  id             String        @id @default(cuid())
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  mpPaymentId    String        @unique // ID do pagamento no Mercado Pago
  amount         Float
  currency       String        @default("BRL")
  status         PaymentStatus @default(PENDING)
  paymentMethod  String? // pix, credit_card, debit_card, boleto
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([subscriptionId])
}

enum PaymentStatus {
  PENDING // Aguardando pagamento
  APPROVED // Pagamento aprovado
  AUTHORIZED // Autorizado (cartão)
  IN_PROCESS // Em processamento
  IN_MEDIATION // Em mediação
  REJECTED // Rejeitado
  CANCELLED // Cancelado
  REFUNDED // Reembolsado
  CHARGED_BACK // Chargeback
}
